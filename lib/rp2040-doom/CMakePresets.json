{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "tbd16",
            "displayName": "DaDa TBD-16 (RP2350 + SSD1309 128x64)",
            "description": "Build for TBD-16: RP2350, SSD1309 128x64 OLED, I2C buttons via STM32",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/tbd16-build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "MinSizeRel",
                "PICO_BOARD": "jtbd16",
                "PICO_PLATFORM": "rp2350-arm-s"
            }
        },
        {
            "name": "minsizerel-pico",
            "displayName": "MinSizeRel for Pimoroni Tiny2040",
            "description": "Configure for Pimoroni Tiny2040 with MinSizeRel build type",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/rp2040-build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "MinSizeRel",
                "PICO_BOARD": "pimoroni_tiny2040",
                "PICO_SDK_PATH": "/opt/pico-sdk",
                "PICO_EXTRAS_PATH": "/opt/pico-extras"
            }
        },
